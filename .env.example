VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Cricket (direct CricAPI — set as Vercel env var for production) ───────────
VITE_CRICAPI_KEY=your_cricapi_key
#   Get it at: https://cricapi.com/

# ── Football (Supabase Edge Function Secret) ──────────────────────────────────
# Set this in Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# API_FOOTBALL_KEY   = Your API-Football key
#                      Get it at: https://www.api-football.com/
