{
  "rewrites": [
    { "source": "/share/:slug", "destination": "/api/share?slug=$1" },
    { "source": "/news/:slug", "destination": "/api/news?slug=$1" },
    { "source": "/((?!api/|sitemap\\.xml|robots\\.txt|favicon\\.svg|icons\\.svg|og-image\\.png|assets/).*)", "destination": "/index.html" }
  ]
}
  